"""
Script para atualizar a planilha Excel com dados extraídos do Clinicys
"""

import pandas as pd
from openpyxl import load_workbook
from openpyxl.styles import Font, PatternFill, Alignment, Border, Side
from datetime import datetime
import logging
import os

logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s - %(levelname)s - %(message)s'
)
logger = logging.getLogger(__name__)


class SheetUpdater:
    def __init__(self):
        """Inicializar o atualizador de planilhas"""
        logger.info("SheetUpdater inicializado")

    def load_processed_data(self, csv_file):
        """Carregar dados processados"""
        try:
            df = pd.read_csv(csv_file, encoding="utf-8-sig")
            logger.info(f"Dados carregados: {len(df)} registros")
            return df
        except Exception as e:
            logger.error(f"Erro ao carregar dados: {str(e)}")
            raise

    def prepare_excel_data(self, df, doctor_name):
        """
        Preparar dados no formato da planilha Excel padrão
        
        Args:
            df: DataFrame com os dados
            doctor_name: Nome do médico
            
        Returns:
            DataFrame formatado para a planilha
        """
        try:
            # Filtrar por médico
            doctor_data = df[df['medico'].str.contains(doctor_name, case=False, na=False)].copy()
            
            if doctor_data.empty:
                logger.warning(f"Nenhum dado encontrado para {doctor_name}")
                return pd.DataFrame()
            
            # Criar DataFrame com as colunas padrão da planilha
            formatted_data = pd.DataFrame({
                'ID Paciente': doctor_data.get('id_paciente', ''),
                'Nome Completo': doctor_data.get('nome_paciente', ''),
                'Telefone (WhatsApp)': doctor_data.get('telefone', ''),
                'Data do Atendimento': doctor_data.get('data_atendimento', ''),
                'Procedimento': doctor_data.get('procedimento', ''),
                'Respondeu?': '',  # Será preenchido manualmente
                'Agendou Consulta?': '',  # Será preenchido manualmente
                'Data Consulta Marcada': '',  # Será preenchido manualmente
                'Médico': doctor_name,
                'Observações': '',  # Será preenchido manualmente
                'Responsável Registro': 'Pam',
            })
            
            logger.info(f"Dados preparados para {doctor_name}: {len(formatted_data)} registros")
            return formatted_data
            
        except Exception as e:
            logger.error(f"Erro ao preparar dados: {str(e)}")
            raise

    def apply_formatting(self, ws):
        """
        Aplicar formatação à planilha
        
        Args:
            ws: Worksheet do openpyxl
        """
        try:
            # Cores
            header_fill = PatternFill(start_color="1F4E78", end_color="1F4E78", fill_type="solid")
            header_font = Font(bold=True, color="FFFFFF", size=11)
            border = Border(
                left=Side(style='thin'),
                right=Side(style='thin'),
                top=Side(style='thin'),
                bottom=Side(style='thin')
            )
            
            # Aplicar formatação ao header
            for cell in ws[1]:
                cell.fill = header_fill
                cell.font = header_font
                cell.border = border
                cell.alignment = Alignment(horizontal='center', vertical='center', wrap_text=True)
            
            # Aplicar bordas ao restante das linhas
            for row in ws.iter_rows(min_row=2, max_row=ws.max_row, min_col=1, max_col=ws.max_column):
                for cell in row:
                    cell.border = border
                    cell.alignment = Alignment(vertical='top', wrap_text=True)
            
            # Ajustar altura das linhas
            ws.row_dimensions[1].height = 25
            
            # Ajustar largura das colunas
            column_widths = {
                'A': 12,  # ID Paciente
                'B': 25,  # Nome Completo
                'C': 18,  # Telefone
                'D': 18,  # Data Atendimento
                'E': 25,  # Procedimento
                'F': 15,  # Respondeu?
                'G': 18,  # Agendou Consulta?
                'H': 18,  # Data Consulta Marcada
                'I': 15,  # Médico
                'J': 25,  # Observações
                'K': 15,  # Responsável
            }
            
            for col, width in column_widths.items():
                ws.column_dimensions[col].width = width
            
            logger.info("Formatação aplicada")
            
        except Exception as e:
            logger.error(f"Erro ao aplicar formatação: {str(e)}")
            raise

    def update_excel(self, template_file, output_file, processed_data_csv, doctor_name):
        """
        Atualizar arquivo Excel com dados do Clinicys
        
        Args:
            template_file: Arquivo Excel template
            output_file: Arquivo Excel de saída
            processed_data_csv: Arquivo CSV com dados processados
            doctor_name: Nome do médico
        """
        try:
            # Carregar dados processados
            df = self.load_processed_data(processed_data_csv)
            
            # Preparar dados
            data_to_insert = self.prepare_excel_data(df, doctor_name)
            
            if data_to_insert.empty:
                logger.warning(f"Nenhum dado para inserir para {doctor_name}")
                return
            
            # Carregar template
            if os.path.exists(template_file):
                wb = load_workbook(template_file)
                ws = wb.active
                logger.info("Template carregado")
            else:
                from openpyxl import Workbook
                wb = Workbook()
                ws = wb.active
                logger.info("Novo arquivo criado")
            
            # Limpar dados antigos (manter apenas header)
            ws.delete_rows(2, ws.max_row)
            
            # Adicionar cabeçalho se não existir
            headers = [
                'ID Paciente', 'Nome Completo', 'Telefone (WhatsApp)',
                'Data do Atendimento', 'Procedimento', 'Respondeu?',
                'Agendou Consulta?', 'Data Consulta Marcada', 'Médico',
                'Observações', 'Responsável Registro'
            ]
            
            if ws.max_row == 0:
                ws.append(headers)
            
            # Inserir dados
            for idx, row in data_to_insert.iterrows():
                ws.append([
                    row.get('ID Paciente', ''),
                    row.get('Nome Completo', ''),
                    row.get('Telefone (WhatsApp)', ''),
                    row.get('Data do Atendimento', ''),
                    row.get('Procedimento', ''),
                    row.get('Respondeu?', ''),
                    row.get('Agendou Consulta?', ''),
                    row.get('Data Consulta Marcada', ''),
                    row.get('Médico', ''),
                    row.get('Observações', ''),
                    row.get('Responsável Registro', ''),
                ])
            
            # Aplicar formatação
            self.apply_formatting(ws)
            
            # Salvar arquivo
            wb.save(output_file)
            logger.info(f"Arquivo salvo: {output_file}")
            
        except Exception as e:
            logger.error(f"Erro ao atualizar Excel: {str(e)}")
            raise

    def update_multiple_doctors(self, template_file, output_dir, processed_data_csv, doctors):
        """
        Atualizar múltiplos arquivos Excel (um por médico)
        
        Args:
            template_file: Arquivo Excel template
            output_dir: Diretório de saída
            processed_data_csv: Arquivo CSV com dados processados
            doctors: Lista de médicos
        """
        try:
            os.makedirs(output_dir, exist_ok=True)
            
            for doctor in doctors:
                output_file = os.path.join(
                    output_dir,
                    f"CONTROLE_DE_ERROS_REATIVAÇÃO_-_{doctor.upper().replace(' ', '_')}.xlsx"
                )
                
                logger.info(f"Atualizando arquivo para {doctor}...")
                self.update_excel(template_file, output_file, processed_data_csv, doctor)
                
        except Exception as e:
            logger.error(f"Erro ao atualizar múltiplos arquivos: {str(e)}")
            raise


# Exemplo de uso
if __name__ == "__main__":
    updater = SheetUpdater()
    
    # Atualizar planilhas para múltiplos médicos
    doctors = ["Dra. Sara", "Dr. André"]
    
    updater.update_multiple_doctors(
        template_file="CONTROLE_DE_ERROS_REATIVAÇÃO_-_DRA__SARÁ__1_.xlsx",
        output_dir="./outputs",
        processed_data_csv="dados_processados.csv",
        doctors=doctors
    )
    
    print("\nArquivos atualizados com sucesso!")
